@using CRM.Application.Contracts.Contracts.Dtos
@using CRM.Domain.Contracts
@model PagedResultDto<ContractDto>

@{
    ViewData["Title"] = "合同管理";
    var currentStatus = ViewBag.Status as int?;
    var canManage = User.IsInRole("Admin") || User.IsInRole("Sales");
    var canCancel = User.IsInRole("Admin");
}

<div class="page-header">
    <div>
        <h2 class="page-title">合同管理</h2>
        <p class="page-subtitle">查询合同台账、跟踪合同状态和回款入口。</p>
    </div>
    @if (canManage)
    {
        <div class="page-actions">
            <a class="btn btn-primary" asp-action="Create">新增合同</a>
        </div>
    }
</div>

<div class="app-card mb-3">
    <div class="app-card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-12 col-md-5">
                <label class="form-label">关键字</label>
                <input name="keyword" value="@ViewBag.Keyword" class="form-control" placeholder="合同编号、合同名称、客户名称" />
            </div>
            <div class="col-12 col-md-3">
                <label class="form-label">合同状态</label>
                <select name="status" class="form-select">
                    <option value="">全部状态</option>
                    @foreach (var status in Enum.GetValues<ContractStatus>())
                    {
                        var value = (int)status;
                        <option value="@value" selected="@(currentStatus == value)">@EnumDisplayHelper.ContractStatusText(status)</option>
                    }
                </select>
            </div>
            <div class="col-12 col-md-4 d-flex flex-wrap gap-2">
                <button class="btn btn-outline-primary btn-sm" type="submit">查询</button>
                <a class="btn btn-outline-secondary btn-sm" asp-action="Index">重置</a>
            </div>
        </form>
    </div>
</div>

<div class="app-card">
    <div class="app-card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle app-table">
                <thead>
                    <tr>
                        <th>合同编号</th>
                        <th>合同名称</th>
                        <th>客户名称</th>
                        <th>联系人</th>
                        <th class="text-end">合同金额</th>
                        <th>签订日期</th>
                        <th>开始日期</th>
                        <th>结束日期</th>
                        <th>状态</th>
                        <th class="text-end">操作</th>
                    </tr>
                </thead>
                <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="10"><div class="empty-state">暂无合同数据</div></td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.ContractNo</td>
                            <td>@item.ContractName</td>
                            <td>@item.CustomerName</td>
                            <td>@item.ContactName</td>
                            <td class="text-end">@item.TotalAmount.ToString("N2")</td>
                            <td>@item.SignDate.ToString("yyyy-MM-dd")</td>
                            <td>@item.StartDate.ToString("yyyy-MM-dd")</td>
                            <td>@item.EndDate.ToString("yyyy-MM-dd")</td>
                            <td><span class="status-badge status-info">@EnumDisplayHelper.ContractStatusText(item.Status)</span></td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-secondary" asp-action="Detail" asp-route-id="@item.Id">详情</a>
                                @if (canManage)
                                {
                                    <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">编辑</a>
                                    @if (canCancel)
                                    {
                                        <form asp-action="Cancel" method="post" class="d-inline" data-confirm="确认作废该合同？作废后不能登记回款。">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <input type="hidden" name="reason" value="页面作废" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">作废</button>
                                        </form>
                                    }
                                }
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
        <div class="px-3 py-2 text-muted small border-top">共 @Model.TotalCount 条记录</div>
    </div>
</div>
