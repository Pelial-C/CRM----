<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CRM Lite</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CRM.Web.styles.css" asp-append-version="true" />
</head>
<body>
@{
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var displayName = User.FindFirst("DisplayName")?.Value ?? User.Identity?.Name;
    var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
}
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">CRM Lite</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar"
                        aria-expanded="false" aria-label="展开导航">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        @if (isAuthenticated)
                        {
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">管理员首页</a>
                                </li>
                                <li class="nav-item"><a class="nav-link text-dark" asp-area="" asp-controller="Customer" asp-action="Index">客户管理</a></li>
                                <li class="nav-item"><a class="nav-link text-dark" asp-area="" asp-controller="Contact" asp-action="Index">联系人管理</a></li>
                                <li class="nav-item"><a class="nav-link text-dark" asp-area="" asp-controller="Contract" asp-action="Index">合同管理</a></li>
                                <li class="nav-item"><a class="nav-link text-dark" asp-area="" asp-controller="Contract" asp-action="Index">回款管理</a></li>
                                <li class="nav-item"><a class="nav-link text-dark" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">用户管理</a></li>
                                <li class="nav-item"><a class="nav-link text-dark" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">基础数据</a></li>
                            }
                            else if (User.IsInRole("Sales"))
                            {
                                <li class="nav-item"><a class="nav-link text-dark" asp-area="Sales" asp-controller="Dashboard" asp-action="Index">销售首页</a></li>
                                <li class="nav-item"><a class="nav-link text-dark" asp-area="" asp-controller="Customer" asp-action="Index">我的客户</a></li>
                                <li class="nav-item"><a class="nav-link text-dark" asp-area="" asp-controller="Contact" asp-action="Index">联系人管理</a></li>
                                <li class="nav-item"><a class="nav-link text-dark" asp-area="" asp-controller="Contract" asp-action="Index">合同管理</a></li>
                                <li class="nav-item"><a class="nav-link text-dark" asp-area="" asp-controller="Contract" asp-action="Index">回款登记</a></li>
                                <li class="nav-item"><a class="nav-link text-dark" asp-area="Sales" asp-controller="Dashboard" asp-action="Index">合同到期提醒</a></li>
                            }
                            else if (User.IsInRole("EnterpriseUser"))
                            {
                                <li class="nav-item"><a class="nav-link text-dark" asp-area="Enterprise" asp-controller="Dashboard" asp-action="Index">企业首页</a></li>
                                <li class="nav-item"><a class="nav-link text-dark" asp-area="" asp-controller="Customer" asp-action="Index">客户信息查看</a></li>
                                <li class="nav-item"><a class="nav-link text-dark" asp-area="" asp-controller="Contract" asp-action="Index">合同信息查看</a></li>
                                <li class="nav-item"><a class="nav-link text-dark" asp-area="" asp-controller="Contract" asp-action="Index">回款计划查看</a></li>
                            }
                            else if (User.IsInRole("CustomerUser"))
                            {
                                <li class="nav-item"><a class="nav-link text-dark" asp-area="CustomerPortal" asp-controller="Dashboard" asp-action="Index">客户门户首页</a></li>
                                <li class="nav-item"><a class="nav-link text-dark" asp-area="CustomerPortal" asp-controller="Contracts" asp-action="Index">我的合同</a></li>
                                <li class="nav-item"><a class="nav-link text-dark" asp-area="CustomerPortal" asp-controller="Contracts" asp-action="Index">我的回款计划</a></li>
                                <li class="nav-item"><a class="nav-link text-dark" asp-area="CustomerPortal" asp-controller="Dashboard" asp-action="Index">企业联系人</a></li>
                            }
                        }
                    </ul>
                    <div class="d-flex align-items-center gap-2">
                        @if (isAuthenticated)
                        {
                            <span class="text-muted small">@displayName（@role）</span>
                            <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="mb-0">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-outline-secondary btn-sm" type="submit">退出登录</button>
                            </form>
                        }
                        else
                        {
                            <a class="btn btn-primary btn-sm" asp-area="" asp-controller="Account" asp-action="Login">登录</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted"></footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
