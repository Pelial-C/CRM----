@{
    var title = ViewData["Title"] as string ?? "CRM Lite";
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    bool IsActive(string target)
    {
        return string.Equals(controller, target, StringComparison.OrdinalIgnoreCase) ||
               (string.Equals(target, "Customer", StringComparison.OrdinalIgnoreCase) &&
                string.Equals(controller, "Contact", StringComparison.OrdinalIgnoreCase));
    }

    string NavClass(string target) => IsActive(target) ? "nav-link active" : "nav-link";
}
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title - CRM Lite</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CRM.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="app-header">
        <nav class="navbar navbar-expand-lg app-navbar">
            <div class="container-fluid content-shell">
                <a class="app-brand" asp-area="" asp-controller="Home" asp-action="Index" aria-label="CRM Lite 首页">
                    <span class="brand-mark">CL</span>
                    <span class="brand-copy">
                        <strong>CRM Lite</strong>
                        <small>客户与合同管理</small>
                    </span>
                </a>
                <button class="navbar-toggler app-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav"
                        aria-expanded="false" aria-label="切换导航">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div id="mainNav" class="collapse navbar-collapse">
                    <ul class="navbar-nav app-nav-links">
                        <li class="nav-item">
                            <a class="@NavClass("Home")" asp-area="" asp-controller="Home" asp-action="Index">工作台</a>
                        </li>
                        <li class="nav-item">
                            <a class="@NavClass("Customer")" asp-area="" asp-controller="Customer" asp-action="Index">客户</a>
                        </li>
                        <li class="nav-item">
                            <a class="@NavClass("Contract")" asp-area="" asp-controller="Contract" asp-action="Index">合同</a>
                        </li>
                    </ul>
                    <div class="app-env">本地运行</div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid content-shell">
        <main role="main" class="app-main">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
