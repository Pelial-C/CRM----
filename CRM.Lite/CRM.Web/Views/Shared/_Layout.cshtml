<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CRM Lite</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CRM.Web.styles.css" asp-append-version="true" />
</head>
<body>
@{
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var displayName = User.FindFirst("DisplayName")?.Value ?? User.Identity?.Name ?? "未登录用户";
    var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "Guest";
    var pageTitle = ViewData["Title"]?.ToString() ?? "工作台";
}

<div class="app-shell @(isAuthenticated ? "" : "app-shell-public")">
    @if (isAuthenticated)
    {
        <aside class="app-sidebar d-none d-lg-flex">
            <div class="sidebar-brand">
                <div class="sidebar-brand-mark">CL</div>
                <div>
                    <div class="sidebar-brand-title">CRM Lite</div>
                    <div class="sidebar-brand-subtitle">合同管理平台</div>
                </div>
            </div>
            <div class="sidebar-role">
                <span>@displayName</span>
                <strong>@role</strong>
            </div>
            <partial name="_RoleMenu" />
        </aside>

        <div class="offcanvas offcanvas-start app-offcanvas" tabindex="-1" id="mobileSidebar" aria-labelledby="mobileSidebarLabel">
            <div class="offcanvas-header">
                <div class="sidebar-brand m-0">
                    <div class="sidebar-brand-mark">CL</div>
                    <div>
                        <h5 class="offcanvas-title sidebar-brand-title" id="mobileSidebarLabel">CRM Lite</h5>
                        <div class="sidebar-brand-subtitle">合同管理平台</div>
                    </div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="关闭"></button>
            </div>
            <div class="offcanvas-body">
                <div class="sidebar-role">
                    <span>@displayName</span>
                    <strong>@role</strong>
                </div>
                <partial name="_RoleMenu" />
            </div>
        </div>
    }

    <div class="app-main">
        <header class="app-topbar">
            <div class="d-flex align-items-center gap-3 min-w-0">
                @if (isAuthenticated)
                {
                    <button class="btn btn-outline-secondary btn-icon d-lg-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#mobileSidebar" aria-controls="mobileSidebar" aria-label="打开菜单">
                        <span aria-hidden="true">☰</span>
                    </button>
                }
                <div class="min-w-0">
                    <div class="topbar-eyebrow">CRM Lite</div>
                    <h1 class="topbar-title">@pageTitle</h1>
                </div>
            </div>
            <div class="topbar-actions">
                @if (isAuthenticated)
                {
                    <div class="topbar-user d-none d-sm-flex">
                        <span>@displayName</span>
                        <strong>@role</strong>
                    </div>
                    <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="mb-0">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-outline-secondary btn-sm" type="submit">退出登录</button>
                    </form>
                }
                else
                {
                    <a class="btn btn-primary btn-sm" asp-area="" asp-controller="Account" asp-action="Login">登录</a>
                }
            </div>
        </header>

        <main role="main" class="app-content">
            @RenderBody()
        </main>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
