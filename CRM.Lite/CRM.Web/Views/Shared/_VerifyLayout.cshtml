<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body { background: #f0f4f8; }
        .verify-hero { border-radius: 1rem; }
        .verify-hero.pass { background: linear-gradient(135deg, #198754 0%, #20c997 100%); color: #fff; }
        .verify-hero.fail { background: linear-gradient(135deg, #dc3545 0%, #fd7e14 100%); color: #fff; }
        .verify-hero.pending { background: linear-gradient(135deg, #0d6efd 0%, #6f42c1 100%); color: #fff; }
        .verify-hero.running { background: linear-gradient(135deg, #6c757d 0%, #495057 100%); color: #fff; }
        .big-icon { font-size: 4rem; line-height: 1; }
        .dev-badge { position: fixed; top: 12px; right: 12px; z-index: 999; }
    </style>
</head>
<body>
    <span class="badge bg-warning text-dark dev-badge">后端自证 · 非正式前端</span>
    <div class="container py-4">
        @RenderBody()
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
