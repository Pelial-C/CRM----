@using CRM.Application.Contracts.Contacts.Dtos
@using CRM.Application.Contracts.Customers.Dtos
@model List<ContactDto>

@{
    ViewData["Title"] = "联系人管理";
    var customers = ViewBag.Customers as List<CustomerSelectDto> ?? new List<CustomerSelectDto>();
    var customerId = ViewBag.CustomerId as int?;
    var canEdit = User.IsInRole("Admin") || User.IsInRole("Sales");
    var canDelete = User.IsInRole("Admin");
}

<div class="page-header">
    <div>
        <h2 class="page-title">联系人管理</h2>
        <p class="page-subtitle">按客户查看和维护联系人、关键决策人信息。</p>
    </div>
    @if (canEdit)
    {
        <div class="page-actions">
            <a class="btn btn-primary" asp-action="Create" asp-route-customerId="@customerId">新增联系人</a>
        </div>
    }
</div>

<div class="app-card mb-3">
    <div class="app-card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-12 col-md-6">
                <label class="form-label">客户</label>
                <select name="customerId" class="form-select">
                    <option value="">请选择客户</option>
                    @foreach (var customer in customers)
                    {
                        <option value="@customer.Id" selected="@(customerId == customer.Id)">@customer.Name</option>
                    }
                </select>
            </div>
            <div class="col-12 col-md-3">
                <button class="btn btn-outline-primary btn-sm" type="submit">查询联系人</button>
            </div>
        </form>
    </div>
</div>

<div class="app-card">
    <div class="app-card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle app-table">
                <thead>
                    <tr>
                        <th>姓名</th>
                        <th>职务</th>
                        <th>手机号</th>
                        <th>邮箱</th>
                        <th>关键决策人</th>
                        @if (canEdit)
                        {
                            <th class="text-end">操作</th>
                        }
                    </tr>
                </thead>
                <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="@(canEdit ? 6 : 5)"><div class="empty-state">请选择客户查看联系人</div></td></tr>
                }
                else
                {
                    foreach (var contact in Model)
                    {
                        <tr>
                            <td>@contact.Name</td>
                            <td>@contact.Title</td>
                            <td>@contact.Phone</td>
                            <td>@contact.Email</td>
                            <td>
                                @if (contact.IsKeyDecisionMaker)
                                {
                                    <span class="status-badge status-info">是</span>
                                }
                                else
                                {
                                    <span class="status-badge status-muted">否</span>
                                }
                            </td>
                            @if (canEdit)
                            {
                                <td class="text-end">
                                    <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@contact.Id">编辑</a>
                                    @if (canDelete)
                                    {
                                        <form asp-action="Delete" method="post" class="d-inline" data-confirm="确认删除该联系人？">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@contact.Id" />
                                            <input type="hidden" name="customerId" value="@contact.CustomerId" />
                                            <button class="btn btn-sm btn-outline-danger" type="submit">删除</button>
                                        </form>
                                    }
                                </td>
                            }
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
