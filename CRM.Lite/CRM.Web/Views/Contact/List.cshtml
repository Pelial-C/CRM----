@model List<CRM.Application.Contracts.Contacts.Dtos.ContactDto>
@{
    ViewData["Title"] = "联系人列表";
    var customerId = (int)ViewBag.CustomerId;
}

<h2>联系人列表 <small class="text-muted">客户Id: @customerId</small></h2>

<a asp-action="Create" asp-route-customerId="@customerId" class="btn btn-success btn-sm mb-2">新增联系人</a>
<a asp-controller="Customer" asp-action="Detail" asp-route-id="@customerId" class="btn btn-secondary btn-sm mb-2">返回客户详情</a>

<table class="table table-bordered table-sm">
    <thead>
        <tr>
            <th>姓名</th>
            <th>职务</th>
            <th>手机号</th>
            <th>邮箱</th>
            <th>关键决策人</th>
            <th>操作</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Title</td>
                <td>@item.Phone</td>
                <td>@item.Email</td>
                <td>@(item.IsKeyDecisionMaker ? "是" : "否")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">编辑</a>
                    <form asp-action="Delete" asp-route-id="@item.Id" asp-route-customerId="@customerId" method="post" style="display:inline" onsubmit="return confirm('确认删除？')">
                        <button type="submit" class="btn btn-sm btn-danger">删除</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
