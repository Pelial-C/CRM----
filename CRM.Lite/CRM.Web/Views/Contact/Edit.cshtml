@model CRM.Application.Contracts.Contacts.Dtos.UpdateContactDto
@{
    ViewData["Title"] = "编辑联系人";
    var customerId = (int)ViewBag.CustomerId;
}

<div class="page-head">
    <div>
        <p class="eyebrow">联系人维护</p>
        <h1>编辑联系人</h1>
        <p>客户 ID：<span class="mono">@customerId</span></p>
    </div>
    <a asp-controller="Customer" asp-action="Detail" asp-route-id="@customerId" class="btn btn-outline-secondary">返回客户</a>
</div>

<form asp-action="Edit" method="post" class="form-workspace">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" name="customerId" value="@customerId" />
    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

    <section class="form-panel narrow-panel">
        <div class="section-title">
            <div>
                <p class="eyebrow">联系信息</p>
                <h2>联系人信息</h2>
            </div>
        </div>
        <div class="form-grid two-column">
            <div>
                <label asp-for="Name" class="form-label">姓名</label>
                <input asp-for="Name" class="form-control" autocomplete="name" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Title" class="form-label">职务</label>
                <input asp-for="Title" class="form-control" />
            </div>
            <div>
                <label asp-for="Phone" class="form-label">手机号</label>
                <input asp-for="Phone" class="form-control" autocomplete="tel" />
                <span asp-validation-for="Phone" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Email" class="form-label">邮箱</label>
                <input asp-for="Email" class="form-control" autocomplete="email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="grid-span-2">
                <label class="check-row">
                    <input asp-for="IsKeyDecisionMaker" class="form-check-input" />
                    <span>关键决策人</span>
                </label>
            </div>
        </div>
    </section>

    <div class="sticky-actions">
        <button type="submit" class="btn btn-primary">保存修改</button>
        <a asp-controller="Customer" asp-action="Detail" asp-route-id="@customerId" class="btn btn-outline-secondary">取消</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
