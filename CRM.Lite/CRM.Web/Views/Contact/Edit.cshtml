@using CRM.Application.Contracts.Customers.Dtos
@model CRM.Application.Contracts.Contacts.Dtos.UpdateContactDto

@{
    ViewData["Title"] = "编辑联系人";
    var customers = ViewBag.Customers as List<CustomerSelectDto> ?? new List<CustomerSelectDto>();
}

<h2 class="mb-3">编辑联系人</h2>

<form asp-action="Edit" method="post" class="card border-0 shadow-sm">
    @Html.AntiForgeryToken()
    <input asp-for="Id" type="hidden" />
    <div class="card-body">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="CustomerId" class="form-label">所属客户</label>
                <select asp-for="CustomerId" class="form-select">
                    @foreach (var customer in customers)
                    {
                        <option value="@customer.Id">@customer.Name</option>
                    }
                </select>
                <span asp-validation-for="CustomerId" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Name" class="form-label">联系人姓名</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="Title" class="form-label">职务</label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="Phone" class="form-label">手机号</label>
                <input asp-for="Phone" class="form-control" />
                <span asp-validation-for="Phone" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="Email" class="form-label">邮箱</label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="col-12">
                <div class="form-check">
                    <input asp-for="IsKeyDecisionMaker" class="form-check-input" />
                    <label asp-for="IsKeyDecisionMaker" class="form-check-label">关键决策人</label>
                </div>
            </div>
        </div>
    </div>
    <div class="card-footer bg-white d-flex gap-2">
        <button class="btn btn-primary" type="submit">保存</button>
        <a class="btn btn-outline-secondary" asp-action="Index" asp-route-customerId="@Model.CustomerId">返回</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
