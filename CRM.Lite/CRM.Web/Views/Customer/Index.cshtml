@model CRM.Application.Contracts.Common.Dtos.PagedResultDto<CRM.Application.Contracts.Customers.Dtos.CustomerDto>
@{
    ViewData["Title"] = "客户列表";
}

<h2>客户列表</h2>

<form method="get" class="row g-2 mb-3">
    <div class="col-auto">
        <input type="text" name="name" value="@Context.Request.Query["name"]" class="form-control" placeholder="企业名称" />
    </div>
    <div class="col-auto">
        <input type="text" name="industry" value="@Context.Request.Query["industry"]" class="form-control" placeholder="所属行业" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary">查询</button>
    </div>
    <div class="col-auto">
        <a asp-action="Create" class="btn btn-success">新增客户</a>
    </div>
</form>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>序号</th>
            <th>企业名称</th>
            <th>统一社会信用代码</th>
            <th>所属行业</th>
            <th>地区</th>
            <th>是否删除</th>
            <th>创建时间</th>
            <th>操作</th>
        </tr>
    </thead>
    <tbody>
        @{
            var rowNumber = (Model.PageIndex - 1) * Model.PageSize;
        }
        @foreach (var item in Model.Items)
        {
            rowNumber++;
            <tr>
                <td>@rowNumber</td>
                <td>@item.Name</td>
                <td>@item.CreditCode</td>
                <td>@item.Industry</td>
                <td>@item.Province @item.City @item.District</td>
                <td>@(item.IsDeleted ? "是" : "否")</td>
                <td>@item.CreationTime.ToString("yyyy-MM-dd")</td>
                <td>
                    <a asp-action="Detail" asp-route-id="@item.Id" class="btn btn-sm btn-info">详情</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">编辑</a>
                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline" onsubmit="return confirm('确认删除？')">
                        <button type="submit" class="btn btn-sm btn-danger">删除</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

<nav>
    <ul class="pagination">
        @if (Model.HasPreviousPage)
        {
            <li class="page-item">
                <a class="page-link" asp-action="Index" asp-route-pageIndex="@(Model.PageIndex - 1)" asp-route-name="@Context.Request.Query["name"]" asp-route-industry="@Context.Request.Query["industry"]">上一页</a>
            </li>
        }
        <li class="page-item active"><span class="page-link">@Model.PageIndex / @Model.TotalPages</span></li>
        @if (Model.HasNextPage)
        {
            <li class="page-item">
                <a class="page-link" asp-action="Index" asp-route-pageIndex="@(Model.PageIndex + 1)" asp-route-name="@Context.Request.Query["name"]" asp-route-industry="@Context.Request.Query["industry"]">下一页</a>
            </li>
        }
    </ul>
</nav>
