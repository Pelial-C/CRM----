@model CRM.Application.Contracts.Customers.Dtos.CreateCustomerDto

@{
    ViewData["Title"] = "新增客户";
}

<div class="page-header">
    <div>
        <h2 class="page-title">新增客户</h2>
        <p class="page-subtitle">录入客户基础资料、地址和备注信息。</p>
    </div>
</div>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <input asp-for="OwnerUserId" type="hidden" />
    <div class="form-section">
        <h3 class="form-section-title">客户资料</h3>
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <div class="row g-3">
            <div class="col-12 col-md-6">
                <label asp-for="Name" class="form-label">企业名称</label>
                <input asp-for="Name" class="form-control" placeholder="请输入企业名称" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="col-12 col-md-6">
                <label asp-for="CreditCode" class="form-label">统一社会信用代码</label>
                <input asp-for="CreditCode" class="form-control" placeholder="18位大写字母或数字，可为空" />
                <span asp-validation-for="CreditCode" class="text-danger"></span>
            </div>
            <div class="col-12 col-md-4">
                <label asp-for="Industry" class="form-label">行业</label>
                <input asp-for="Industry" class="form-control" />
                <span asp-validation-for="Industry" class="text-danger"></span>
            </div>
            <div class="col-12 col-md-2">
                <label asp-for="Province" class="form-label">省</label>
                <input asp-for="Province" class="form-control" />
                <span asp-validation-for="Province" class="text-danger"></span>
            </div>
            <div class="col-12 col-md-2">
                <label asp-for="City" class="form-label">市</label>
                <input asp-for="City" class="form-control" />
                <span asp-validation-for="City" class="text-danger"></span>
            </div>
            <div class="col-12 col-md-2">
                <label asp-for="District" class="form-label">区</label>
                <input asp-for="District" class="form-control" />
                <span asp-validation-for="District" class="text-danger"></span>
            </div>
            <div class="col-12">
                <label asp-for="DetailAddress" class="form-label">详细地址</label>
                <input asp-for="DetailAddress" class="form-control" />
                <span asp-validation-for="DetailAddress" class="text-danger"></span>
            </div>
            <div class="col-12">
                <label asp-for="Remark" class="form-label">备注</label>
                <textarea asp-for="Remark" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Remark" class="text-danger"></span>
            </div>
        </div>
    </div>
    <div class="form-actions">
        <button class="btn btn-primary" type="submit">保存</button>
        <a class="btn btn-outline-secondary" asp-action="Index">返回</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
