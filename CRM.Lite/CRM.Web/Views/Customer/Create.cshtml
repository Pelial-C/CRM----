@model CRM.Application.Contracts.Customers.Dtos.CreateCustomerDto
@{
    ViewData["Title"] = "新增客户";
}

<div class="page-head">
    <div>
        <p class="eyebrow">客户建档</p>
        <h1>新增客户</h1>
        <p>建立客户主体档案，后续可在详情页维护联系人和合同。</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">返回列表</a>
</div>

<form asp-action="Create" method="post" class="form-workspace">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

    <section class="form-panel">
        <div class="section-title">
            <div>
                <p class="eyebrow">主体档案</p>
                <h2>客户档案</h2>
            </div>
        </div>
        <div class="form-grid">
            <div class="grid-span-2">
                <label asp-for="Name" class="form-label">企业名称</label>
                <input asp-for="Name" class="form-control" autocomplete="organization" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="CreditCode" class="form-label">统一社会信用代码</label>
                <input asp-for="CreditCode" class="form-control mono-input" />
                <span asp-validation-for="CreditCode" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Industry" class="form-label">所属行业</label>
                <input asp-for="Industry" class="form-control" />
            </div>
            <div>
                <label asp-for="Province" class="form-label">省份</label>
                <input asp-for="Province" class="form-control" />
            </div>
            <div>
                <label asp-for="City" class="form-label">城市</label>
                <input asp-for="City" class="form-control" />
            </div>
            <div>
                <label asp-for="District" class="form-label">区县</label>
                <input asp-for="District" class="form-control" />
            </div>
            <div class="grid-span-3">
                <label asp-for="DetailAddress" class="form-label">详细地址</label>
                <input asp-for="DetailAddress" class="form-control" autocomplete="street-address" />
            </div>
            <div class="grid-span-3">
                <label asp-for="Remark" class="form-label">备注</label>
                <textarea asp-for="Remark" class="form-control" rows="3"></textarea>
            </div>
        </div>
    </section>

    <div class="sticky-actions">
        <button type="submit" class="btn btn-primary">保存客户</button>
        <a asp-action="Index" class="btn btn-outline-secondary">取消</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
