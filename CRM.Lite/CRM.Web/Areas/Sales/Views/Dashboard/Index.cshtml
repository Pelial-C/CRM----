@model CRM.Web.Areas.Sales.Controllers.SalesDashboardViewModel

@{
    ViewData["Title"] = "销售首页";
}

<h2 class="mb-3">销售/企业业务端</h2>
<p class="text-muted">管理自己负责的客户、联系人、合同和回款登记。</p>

<div class="row g-3">
    <div class="col-md-3"><div class="card shadow-sm border-0"><div class="card-body"><div class="text-muted">我的客户</div><div class="fs-2 fw-bold">@Model.CustomerCount</div></div></div></div>
    <div class="col-md-3"><div class="card shadow-sm border-0"><div class="card-body"><div class="text-muted">我的合同</div><div class="fs-2 fw-bold">@Model.ContractCount</div></div></div></div>
    <div class="col-md-3"><div class="card shadow-sm border-0"><div class="card-body"><div class="text-muted">执行中合同</div><div class="fs-2 fw-bold">@Model.ExecutingContractCount</div></div></div></div>
    <div class="col-md-3"><div class="card shadow-sm border-0"><div class="card-body"><div class="text-muted">到期提醒</div><div class="fs-2 fw-bold">@Model.DueSoonContractCount</div></div></div></div>
</div>

<div class="mt-4 d-flex gap-2">
    <a class="btn btn-primary" asp-area="" asp-controller="Customer" asp-action="Index">我的客户</a>
    <a class="btn btn-outline-primary" asp-area="" asp-controller="Contract" asp-action="Index">合同管理</a>
</div>
