@model CRM.Web.Areas.Sales.Controllers.SalesDashboardViewModel

@{
    ViewData["Title"] = "销售首页";
    var displayName = User.FindFirst("DisplayName")?.Value ?? User.Identity?.Name;
    var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
}

<div class="page-header">
    <div>
        <h2 class="page-title">销售首页</h2>
        <p class="page-subtitle">管理自己负责的客户、联系人、合同和回款登记。</p>
    </div>
    <div class="page-actions text-muted">当前用户：@displayName（@role）</div>
</div>

<div class="row g-3">
    <div class="col-12 col-sm-6 col-xl-3"><div class="stat-card"><div class="stat-label">我的客户</div><div class="stat-value">@Model.CustomerCount</div><div class="stat-hint">负责人为当前销售</div></div></div>
    <div class="col-12 col-sm-6 col-xl-3"><div class="stat-card"><div class="stat-label">我的合同</div><div class="stat-value">@Model.ContractCount</div><div class="stat-hint">负责人为当前销售</div></div></div>
    <div class="col-12 col-sm-6 col-xl-3"><div class="stat-card"><div class="stat-label">本月待回款</div><div class="stat-value">@Model.ExecutingContractCount</div><div class="stat-hint">后续可接入回款月份统计</div></div></div>
    <div class="col-12 col-sm-6 col-xl-3"><div class="stat-card"><div class="stat-label">即将到期合同</div><div class="stat-value">@Model.DueSoonContractCount</div><div class="stat-hint">未来 30 天内到期</div></div></div>
</div>

<div class="app-card mt-4">
    <div class="app-card-body">
        <h3 class="form-section-title">快捷入口</h3>
        <div class="quick-action-grid">
            <a class="quick-action" asp-area="" asp-controller="Customer" asp-action="Index">我的客户</a>
            <a class="quick-action" asp-area="" asp-controller="Contact" asp-action="Index">联系人管理</a>
            <a class="quick-action" asp-area="" asp-controller="Contract" asp-action="Index">合同管理</a>
            <a class="quick-action" asp-area="" asp-controller="Contract" asp-action="Index">回款登记</a>
        </div>
    </div>
</div>
