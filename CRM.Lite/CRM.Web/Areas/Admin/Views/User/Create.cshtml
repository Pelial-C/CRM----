@using CRM.Domain.Shared.Enums
@model CRM.Web.Models.AdminUsers.CreateUserViewModel

@{
    ViewData["Title"] = "新增用户";
}

<div class="page-header">
    <div>
        <h2 class="page-title">新增用户</h2>
        <p class="page-subtitle">创建登录账号并分配角色入口。</p>
    </div>
</div>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <div class="form-section">
        <h3 class="form-section-title">账号信息</h3>
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <div class="row g-3">
            <div class="col-12 col-md-6">
                <label asp-for="UserName" class="form-label">用户名</label>
                <input asp-for="UserName" class="form-control" />
                <span asp-validation-for="UserName" class="text-danger"></span>
            </div>
            <div class="col-12 col-md-6">
                <label asp-for="DisplayName" class="form-label">显示名称</label>
                <input asp-for="DisplayName" class="form-control" />
                <span asp-validation-for="DisplayName" class="text-danger"></span>
            </div>
            <div class="col-12 col-md-6">
                <label asp-for="Password" class="form-label">初始密码</label>
                <input asp-for="Password" class="form-control" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            <div class="col-12 col-md-6">
                <label asp-for="Role" class="form-label">角色</label>
                <select asp-for="Role" class="form-select" asp-items="Html.GetEnumSelectList<UserRole>()"></select>
                <span asp-validation-for="Role" class="text-danger"></span>
            </div>
            <div class="col-12 col-md-6">
                <label asp-for="Email" class="form-label">邮箱</label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="col-12 col-md-6">
                <label asp-for="Phone" class="form-label">手机号</label>
                <input asp-for="Phone" class="form-control" />
                <span asp-validation-for="Phone" class="text-danger"></span>
            </div>
            <div class="col-12 col-md-6">
                <label asp-for="RelatedCustomerId" class="form-label">关联客户ID</label>
                <input asp-for="RelatedCustomerId" class="form-control" placeholder="CustomerUser 可填写" />
                <span asp-validation-for="RelatedCustomerId" class="text-danger"></span>
            </div>
            <div class="col-12 col-md-6 d-flex align-items-end">
                <div class="form-check">
                    <input asp-for="IsActive" class="form-check-input" />
                    <label asp-for="IsActive" class="form-check-label">启用账号</label>
                </div>
            </div>
        </div>
    </div>
    <div class="form-actions">
        <button class="btn btn-primary" type="submit">保存</button>
        <a class="btn btn-outline-secondary" asp-action="Index">返回</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
