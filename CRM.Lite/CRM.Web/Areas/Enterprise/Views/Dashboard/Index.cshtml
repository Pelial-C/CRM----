@model CRM.Web.Areas.Enterprise.Controllers.EnterpriseDashboardViewModel

@{
    ViewData["Title"] = "企业首页";
    var displayName = User.FindFirst("DisplayName")?.Value ?? User.Identity?.Name;
    var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
}

<div class="page-header">
    <div>
        <h2 class="page-title">企业普通用户首页</h2>
        <p class="page-subtitle">查看客户、合同和回款计划信息，不允许执行删除、作废或登记回款等敏感操作。</p>
    </div>
    <div class="page-actions text-muted">当前用户：@displayName（@role）</div>
</div>

<div class="row g-3">
    <div class="col-12 col-md-3"><div class="stat-card"><div class="stat-label">客户信息查看</div><div class="stat-value">@Model.CustomerCount</div><div class="stat-hint">只读访问</div></div></div>
    <div class="col-12 col-md-3"><div class="stat-card"><div class="stat-label">合同信息查看</div><div class="stat-value">@Model.ContractCount</div><div class="stat-hint">只读访问</div></div></div>
    <div class="col-12 col-md-3"><div class="stat-card"><div class="stat-label">回款计划查看</div><div class="stat-value">@Model.PaymentPlanCount</div><div class="stat-hint">只读访问</div></div></div>
    <div class="col-12 col-md-3"><div class="stat-card"><div class="stat-label">系统通知</div><div class="stat-value">0</div><div class="stat-hint">后续可接入通知服务</div></div></div>
</div>

<div class="app-card mt-4">
    <div class="app-card-body">
        <h3 class="form-section-title">快捷入口</h3>
        <div class="quick-action-grid">
            <a class="quick-action" asp-area="" asp-controller="Customer" asp-action="Index">客户信息查看</a>
            <a class="quick-action" asp-area="" asp-controller="Contract" asp-action="Index">合同信息查看</a>
            <a class="quick-action" asp-area="" asp-controller="Contract" asp-action="Index">回款计划查看</a>
            <a class="quick-action" href="#">系统通知（后续）</a>
        </div>
    </div>
</div>
